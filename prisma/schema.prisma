generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usage {
  id        Int      @id @default(autoincrement())
  school    String
  service   String
  requests  Int
  cost      Float
  createdAt DateTime @default(now())
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  role  String
}

model Logs {
  id        Int      @id @default(autoincrement())
  service   String
  latency   Int
  status    Int
  createdAt DateTime @default(now())
}
